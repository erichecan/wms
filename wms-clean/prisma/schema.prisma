generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// Updated 2026-02-26T08:35:00Z - 货架 = rack
model Bin {
  id          String    @id
  col         String
  rack        Int
  row         Int
  sku         String?
  quantity    Int       @default(0)
  items       Json      @default("[]")
  inboundTime DateTime? @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([col, row, rack])
}

// Updated 2026-02-27T05:18:00Z - 库位变化记录
model BinMoveLog {
  id         String   @id @default(cuid())
  sourceIds Json     // ["K1-L1-R1", "K1-L1-R2"]
  targetId  String   // K1-L1-R5
  movedAt   DateTime @default(now())
}

model Product {
  sku         String  @id
  name        String?
  description String?
  category    String?
}

// 2026-02-27 仓库人员排班
model Personnel {
  id   String @id @default(cuid())
  name String
  code String? // 工号
  createdAt DateTime @default(now())
}

model ScheduleTask {
  id           String   @id @default(cuid())
  title        String
  taskType     String   // 拣货|包装|收货|盘点|分货|整理库位
  personnelIds Json     @default("[]") // ["id1","id2"]
  startAt      DateTime
  endAt        DateTime
  status       String   @default("scheduled") // scheduled|in_progress|completed|cancelled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([startAt, endAt])
}
